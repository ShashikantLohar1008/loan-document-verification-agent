<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.10.xsd">

    <changeSet id="003-document-ocr_001" author="shashikant">
        <addColumn tableName="documents">
            <column name="ocr_status" type="VARCHAR(50)"/>
            <column name="ocr_text" type="TEXT"/>
            <column name="ocr_processed_at" type="TIMESTAMP"/>
            <column name="ocr_error_message" type="VARCHAR(1000)"/>
        </addColumn>
    </changeSet>
</databaseChangeLog>
