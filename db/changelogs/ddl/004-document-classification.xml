<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.10.xsd">

    <changeSet id="004-document-classification_001" author="shashikant">
        <addColumn tableName="documents">
            <column name="classification_status" type="VARCHAR(50)"/>
            <column name="classified_document_type" type="VARCHAR(50)"/>
            <column name="classification_confidence" type="DOUBLE PRECISION"/>
            <column name="classification_reason" type="VARCHAR(1000)"/>
            <column name="classified_at" type="TIMESTAMP"/>
        </addColumn>
    </changeSet>
</databaseChangeLog>
