<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.10.xsd">

    <changeSet id="006-document-ai-summary_001" author="shashikant">
        <addColumn tableName="documents">
            <column name="ai_summary_status" type="VARCHAR(50)"/>
            <column name="ai_summary" type="TEXT"/>
            <column name="ai_summary_generated_at" type="TIMESTAMP"/>
            <column name="ai_summary_error_message" type="VARCHAR(1000)"/>
        </addColumn>
    </changeSet>
</databaseChangeLog>
