<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.10.xsd">

    <changeSet id="007-document-audit-history_001" author="shashikant" context="ddl">
        <createTable tableName="document_audit_history">
            <column name="audit_key" type="BIGSERIAL">
                <constraints primaryKey="true" primaryKeyName="pk_document_audit_history"/>
            </column>
            <column name="document_key" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="event_type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="event_status" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="score" type="DOUBLE PRECISION"/>
            <column name="summary" type="TEXT"/>
            <column name="details" type="TEXT"/>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint baseTableName="document_audit_history"
            baseColumnNames="document_key"
            constraintName="fk_document_audit_history_document"
            referencedTableName="documents"
            referencedColumnNames="document_key"/>

        <createIndex tableName="document_audit_history" indexName="idx_document_audit_history_document_key">
            <column name="document_key"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
